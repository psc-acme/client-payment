{
    "name": "psc-acme/client-payment",
    "description": "Package client-payment for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ClientPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "carbon/carbon": "^3.0",
        "symfony/symfony": "^6.3",
        "nikic/php-parser": "^5.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}